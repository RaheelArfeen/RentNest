// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum RentalStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
}

enum PaymentProvider {
  STRIPE
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  phone     String?
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  properties     Property[]      @relation("LandlordProperties")
  rentalRequests RentalRequest[] @relation("TenantRentalRequests")
  reviews        Review[]        @relation("TenantReviews")

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  properties Property[]

  @@map("categories")
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  price       Float
  amenities   String[]
  images      String[]
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  landlordId String
  landlord   User   @relation("LandlordProperties", fields: [landlordId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  rentalRequests RentalRequest[]
  reviews        Review[]

  @@map("properties")
}

model RentalRequest {
  id        String       @id @default(uuid())
  startDate DateTime
  endDate   DateTime
  status    RentalStatus @default(PENDING)
  message   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenantId String
  tenant   User   @relation("TenantRentalRequests", fields: [tenantId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  payment Payment?

  @@map("rental_requests")
}

model Payment {
  id            String          @id @default(uuid())
  transactionId String          @unique
  amount        Float
  method        String
  provider      PaymentProvider
  status        PaymentStatus   @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  rentalRequestId String        @unique
  rentalRequest   RentalRequest @relation(fields: [rentalRequestId], references: [id])

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  tenantId String
  tenant   User   @relation("TenantReviews", fields: [tenantId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  @@map("reviews")
}
